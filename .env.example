# Copy relevant sections to `.env.cloud.local`, `.env.dev`, and/or `.env` at the repo root.
# Real files are gitignored; this file is the template only.
# Load order (CLI, vitest, db:migrate, next.config, etc.): `.env.cloud.local` → `.env.dev` → `.env`
# (dotenv does not override variables already set in the shell.)

# -----------------------------------------------------------------------------
# Auth (V1+ better-auth) — Google/GitHub OAuth + email OTP / magic link
# Google "SSO" uses an OAuth 2.0 Web client (Google Cloud Console → APIs & Services →
# Credentials). You need Client ID + Client Secret, not a generic "API key".
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email OTP sign-in (better-auth emailOTP plugin → Resend REST API)
# Automated: `pnpm cloud:provision -- --env dev --write` (needs RESEND_BOOTSTRAP_API_KEY
# with full_access in .env.cloud.local — one-time from https://resend.com/api-keys)
# RESEND_BOOTSTRAP_API_KEY=   # provision only; not written to output files
# RESEND_API_KEY=             # emitted: clearbolt-<env> sending_access key
# RESEND_FROM_DOMAIN=         # staging/prod noreply@ (dev uses onboarding@resend.dev)
# Without Resend in dev, OTP is logged to the `pnpm dev` terminal.
# CLEARBOLT_AUTH_OTP_CONSOLE=false   # set to disable console OTP logging
# Option B — Cloudflare (e.g. send from a Worker via Email Workers / bindings, or relay to
# another provider — exact env names depend on implementation; see ADR when wired)

# From address / domain must match the provider (SPF/DKIM as required)
# AUTH_EMAIL_FROM=noreply@your.example.com

# -----------------------------------------------------------------------------
# Local paths
# -----------------------------------------------------------------------------
# DATA_DIR=/absolute/or/relative/path/to/data

# -----------------------------------------------------------------------------
# Database (Prisma — packages/db only; pnpm db:migrate / db:migrate:dev)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://…@…neon.tech/neondb?sslmode=require&…
# BETTER_AUTH_SECRET=   # openssl rand -base64 32
# BETTER_AUTH_URL=http://localhost:3000
# Dev bypass when auth not wired (internal user id, not email):
# CLEARBOLT_DEV_USER_ID=
# CLEARBOLT_DEV_WORKSPACE_ID=

# -----------------------------------------------------------------------------
# Cloud storage (R2 + Neon) — set CLEARBOLT_STORAGE=cloud when vars below are present
# -----------------------------------------------------------------------------
# CLEARBOLT_STORAGE=cloud
# Optional: unpooled URL for Prisma migrations / admin tools
# DATABASE_URL_UNPOOLED=postgresql://…

# Cloudflare R2 (S3-compatible evidence bucket)
# CLOUDFLARE_ACCOUNT_ID=
# R2_EVIDENCE_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Optional custom endpoint (default: https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com)
# R2_ENDPOINT=

# -----------------------------------------------------------------------------
# Cloud bootstrap / provision (neonctl, wrangler) — see docs/operations/cloud-bootstrap.md
# -----------------------------------------------------------------------------
# NEON_API_KEY=
# NEON_ORG_ID=
# NEON_REGION_ID=aws-us-east-2

# -----------------------------------------------------------------------------
# OpenRouter — dedup LLM blend, optional scrape embeddings, CI live tests
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=
# Pin chat model for dedup (unset = pick free from catalog, cached)
# CLEARBOLT_DEDUP_LLM_MODEL=
# CLEARBOLT_DEDUP_LLM_WEIGHT=0.3
# CLEARBOLT_DEDUP_LLM_MODEL_LIST_TTL_MS=21600000
# Optional referer header for OpenRouter
# CLEARBOLT_OPENROUTER_HTTP_REFERER=https://github.com/your-org/clearbolt

# Optional: embed listing body text on scrape (1 = on). Model unset = free then cheapest from embeddings catalog
# CLEARBOLT_DEDUP_EMBED=1
# CLEARBOLT_DEDUP_EMBED_MODEL=
# CLEARBOLT_DEDUP_EMBED_MODEL_LIST_TTL_MS=21600000

# -----------------------------------------------------------------------------
# CLI / scraper
# -----------------------------------------------------------------------------
# Crawl politeness (robots.txt + minimum gap between requests to the same host)
# CLEARBOLT_SCRAPER_ROBOTS=1          # 0 = skip robots.txt checks (tests only)
# CLEARBOLT_SCRAPER_MIN_GAP_MS=1000   # floor; max with robots Crawl-delay when present
# CLEARBOLT_SCRAPER_USER_AGENT=ClearboltScraper

# Proxies (HTTP/HTTPS gateway; same env on localhost CLI and Fly scraper-service).
#
# Recommended (min cost): direct-then-residential — scrape from your IP first; only failed
# hosts burn residential bandwidth (~$1.75–2.50/GB at ~300 KB/listing ≈ 3k listings/GB).
# Skip datacenter unless you already have a cheap DC plan; BizBuySell often blocks DC IPs.
#
# CLEARBOLT_PROXY_POLICY=direct-then-residential
# Use http:// for the gateway (not https://). One port is enough (e.g. Decodo :10001).
# CLEARBOLT_PROXY_RESIDENTIAL=http://USERNAME:PASSWORD@us.decodo.com:10001
# Multi-port pool (gitignored proxy-endpoints.local.txt; see proxy-endpoints.example.txt):
# CLEARBOLT_PROXY_ENDPOINTS_FILE=proxy-endpoints.local.txt
# Decodo sticky session (10 min default): builds user-{id}-country-us-session-{id}-sessionduration-10
# CLEARBOLT_PROXY_USERNAME_STYLE=decodo
# CLEARBOLT_PROXY_SESSION_ID=clearbolt-catalog-1
# CLEARBOLT_PROXY_SESSION_DURATION_MINUTES=10     # Decodo sticky lifetime (matches dashboard)
# CLEARBOLT_PROXY_SESSION_ROTATE_BUFFER_MS=60000  # rotate session key 60s before expiry
# CLEARBOLT_BIZBUYSELL_INGEST_HTTP=1              # force HTTP+rotating proxy per worker (default when multi-port file)
# CLEARBOLT_PROXY_COUNTRY=us
# Undici defaults to 10s connect — too short for residential; catalog uses 60s/120s unless overridden:
# CLEARBOLT_PROXY_CONNECT_TIMEOUT_MS=60000
# CLEARBOLT_PROXY_BODY_TIMEOUT_MS=120000
#
# Optional datacenter tier (datacenter-first policy only):
# CLEARBOLT_PROXY_POLICY=datacenter-first
# CLEARBOLT_PROXY_DATACENTER=http://USERNAME:PASSWORD@gate.example:12345
#
# Policies: direct | datacenter | datacenter-first | direct-then-residential | residential
#
# Provider setup (pick one residential vendor; examples — check current pricing):
#   IPRoyal residential — geo in username: USER_country-us (or use CLEARBOLT_PROXY_COUNTRY=us)
#   Smartproxy — user-country-us in dashboard / username
#   Oxylabs — customer-USER-cc-US in username (may not match _country-us suffix; set username fully in URL)
#
# Sticky session (appended to username as -sessid-{id}; override suffix with CLEARBOLT_PROXY_SESSION_SUFFIX)
# CLEARBOLT_PROXY_SESSION_ID=catalog-run-abc
# CLEARBOLT_PROXY_SESSION_SUFFIX=-sessid-{session}
#
# Fly (after deploy): fly secrets set -a clearbolt-scraper \
#   CLEARBOLT_PROXY_POLICY=direct-then-residential \
#   CLEARBOLT_PROXY_RESIDENTIAL='http://...' \
#   CLEARBOLT_PROXY_COUNTRY=us

# CLEARBOLT_SCRAPE_LIMIT=10
# CLEARBOLT_SKIP_BROWSER=1   # HTTP-only; BizBuySell detail pages will fail after WAF marks host
# Fly / local scraper service (Playwright). Web app calls this instead of spawning scrape in-process.
# Terminal 1: pnpm scraper-service:dev
# Terminal 2: pnpm dev
# CLEARBOLT_SCRAPER_SERVICE_URL=http://127.0.0.1:8791
# CLEARBOLT_SCRAPER_SERVICE_SECRET=   # optional Bearer token (set same on Fly + web)
# Deploy: fly deploy --config apps/scraper-service/fly.toml

# CLEARBOLT_SCRAPE_CONCURRENCY=8   # optional: lower than proxy file line count (default = all lines)
# CLEARBOLT_SCRAPE_FAILURE_LOG=data/ingest-failures.jsonl   # append each failed URL + error
# Listing detail re-fetch cooldown (default 24h). Set hours or ms to 0 to always refetch.
# CLEARBOLT_LISTING_FETCH_COOLDOWN_HOURS=24
# CLEARBOLT_LISTING_FETCH_MIN_INTERVAL_MS=86400000
# CLEARBOLT_LISTING_FETCH_COOLDOWN=0            # alias: disable cooldown
# CLEARBOLT_LISTING_FETCH_SKIP_KNOWN=1            # resume ingest: skip any listing already in metadata
# Catalog: pnpm clearbolt catalog --discover-only --discover-out data/ca-refs.json
#          CLEARBOLT_LISTING_FETCH_SKIP_KNOWN=1 CLEARBOLT_SCRAPE_CONCURRENCY=10 pnpm clearbolt catalog --refs-file data/ca-refs.json
# Paginated state catalog (e.g. all California listings):
#   pnpm clearbolt catalog
#   pnpm clearbolt catalog https://www.bizbuysell.com/california-businesses-for-sale/ --pages 0 --ingest 0
# CLEARBOLT_CATALOG_MAX_PAGES=200   # 0 = walk until no next page
# CLEARBOLT_CATALOG_MAX_LISTINGS=0  # 0 = no discovery cap

# Object storage layout (R2 when CLEARBOLT_STORAGE=cloud):
#   shared/<adapter>/<sha256>.html          — raw HTML/JSON evidence
#   shared/<adapter>/processed/markdown/  — listing markdown (.md)
#   shared/<adapter>/processed/structured/ — parsed + metadata JSON
#   shared/<adapter>/processed/embedding/  — vector JSON (when CLEARBOLT_DEDUP_EMBED=1)
#   shared/<adapter>/processed/classification/ — industry/geo heuristic (LLM in V1+)
# Neon SourceRecord.processedArtifacts holds R2 pointers; Postgres also keeps parsedFields + optional bodyEmbedding for FTS/dedup.
# CLEARBOLT_SEARCH_EXPAND_LLM=1
# CLEARBOLT_SEARCH_EXPAND_MODEL=google/gemini-2.0-flash-001

# Serper.dev Google SERP (https://serper.dev) — discover BizBuySell listing URLs
# without scraping the search results page (avoids Akamai on search HTML).
# SERP_DEV_API_KEY=          # preferred name in Clearbolt
# SERPER_API_KEY=            # alias (Serper dashboard name)
# Primary discovery is direct BizBuySell HTML (catalog/search). Serper only supplements gaps.
# CLEARBOLT_BIZBUYSELL_DISCOVERY=direct
# CLEARBOLT_BIZBUYSELL_SERPER_SUPPLEMENT=1   # 0 = never call Serper
# With Decodo configured, Playwright is used for all BizBuySell fetches (not only WAF fallback):
# CLEARBOLT_BIZBUYSELL_BROWSER_FIRST=1       # opt-in Playwright-first (often 403 headless on BBS)
# Default with proxy: HTTP+residential, Playwright only on WAF escalation
# CLEARBOLT_BROWSER_WAF_WAIT_MS=12000        # post-load wait for Akamai on Playwright
# CLEARBOLT_SCRAPER_DEBUG=1                  # log proxy tier at browser launch
# CLEARBOLT_BROWSER_HEADLESS=0               # headed Chromium (or use CLI --headed)
# CLEARBOLT_BROWSER_SLOW_MO=100              # ms delay between actions when headed
# Browser driver (default `playwright`). `patchright` is a drop-in fork that patches
# CDP-level fingerprint tells (Runtime.enable, Console.enable, --enable-automation)
# that vanilla Playwright cannot hide. Use for Akamai/DataDome-heavy sources
# (LoopNet, DealStream). Requires one-time install:
#   pnpm add patchright -F @clearbolt/scraper && npx patchright install chrome
# Stealth mode forces channel=chrome, viewport=null, headless=false, and skips
# our custom UA/extra headers (per patchright docs).
#
# Profile dir resolution (highest wins):
#   1. CLEARBOLT_BROWSER_PROFILE_DIR — absolute path; you own the slot
#   2. CLEARBOLT_BROWSER_PROFILE_SLOT — name only; resolves under DATA_DIR/browser-profiles/patchright-<slot>
#   3. CLEARBOLT_PROXY_SESSION_ID — fallback name (useful when you already use it)
#   4. literal "default"
# Deliberately NOT tied to the rotating proxy session key — Akamai trusts warm
# cookies, so the browser profile must outlive Decodo's ~10-minute session window.
# CLEARBOLT_BROWSER_DRIVER=patchright
# CLEARBOLT_BROWSER_PROFILE_DIR=
# CLEARBOLT_BROWSER_PROFILE_SLOT=loopnet
# When the patchright profile gets flagged (Akamai escalates to 403 after a few runs),
# nuke it and start fresh: `rm -rf data/browser-profiles/`. Persistent profiles
# trade "warm trust" for "permanent fingerprint memory" — sometimes you want both,
# sometimes a fresh profile is the only way to get back to status 200.
#
# Dump rendered HTML when a browser fetch returns 0 listing anchors — the only way
# to distinguish a real-but-empty catalog page from an interstitial that returns
# HTTP 200 with a "checking your browser" body. Output: <DIR>/<host>-<driver>-<ts>.html
# CLEARBOLT_BROWSER_DUMP_EMPTY=1
# CLEARBOLT_BROWSER_DUMP_DIR=data/debug/browser

# -----------------------------------------------------------------------------
# Broker-site crawl (clearbolt broker-site crawl)
# -----------------------------------------------------------------------------
# CLEARBOLT_BROKER_SITE_ALLOWLIST=example-broker.com,sunbeltnetwork.com
# CLEARBOLT_BROKER_SITE_LLM_EXTRACT=1
# CLEARBOLT_BROKER_SITE_LLM_MODEL=
# CLEARBOLT_BROKER_SITE_MAX_INDEX_PAGES=0

# -----------------------------------------------------------------------------
# BizBuySell fixture refresh (scripts/refresh-bizbuysell-fixture-cache.mjs)
# -----------------------------------------------------------------------------
# BIZBUYSELL_FIXTURE_SEARCH_URL=
# BIZBUYSELL_FIXTURE_CACHE_LIMIT=5
# BIZBUYSELL_FIXTURE_MASK_HTML=1

# -----------------------------------------------------------------------------
# Dev-only / dangerous (see package scripts before using)
# -----------------------------------------------------------------------------
# CLEARBOLT_DEV_METADATA_RESET=1
# CLEARBOLT_FIXTURES_RECOVER=1
